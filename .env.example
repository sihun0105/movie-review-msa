SECRET=

# JWT 설정
# 중요: JWT_ACCESS_SECRET 값은 프론트엔드의 NEXTAUTH_SECRET과 반드시 동일해야 합니다.
# NextAuth가 이 시크릿으로 JWT를 발급하고, 백엔드 JwtStrategy가 동일한 시크릿으로 검증합니다.
# 최소 32자 이상의 무작위 문자열 사용 (예: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRE_TIME=3600s
REFRESH_TOKEN_EXPIRE_TIME=7d
MOVIE_SECRET=

#PRISMA 설정
DATABASE_URL="mysql://root:root@mysql:3306/moviereview"

#MULTER 설정
MULTER_DEST=./uploads

# 서비스 포트 (각 마이크로서비스가 gRPC 수신에 사용하는 포트)
API_GATEWAY_PORT=3030
AUTH_GRPC_PORT=50051
USER_GRPC_PORT=50052
REPLY_GRPC_PORT=50053
MOVIE_GRPC_PORT=50054
ARTICLE_GRPC_PORT=50055
CHAT_GRPC_PORT=50057
CHAT_WS_PORT=3031
MATCH_GRPC_PORT=50059

# 서비스 클라이언트 URL (api-gateway 및 서비스 간 통신에 사용)
# 개발환경: 0.0.0.0:<PORT>
# Docker 환경: <서비스명>:<PORT>  (예: auth-service:50051)
AUTH_GRPC_URL=0.0.0.0:50051
USER_GRPC_URL=0.0.0.0:50052
REPLY_GRPC_URL=0.0.0.0:50053
MOVIE_GRPC_URL=0.0.0.0:50054
ARTICLE_GRPC_URL=0.0.0.0:50055
CHAT_GRPC_URL=0.0.0.0:50057
MATCH_GRPC_URL=0.0.0.0:50059

# CORS 설정
# 허용할 도메인을 콤마로 구분하여 입력 (공백 없이)
# 예) ALLOWED_ORIGINS=https://drunkenmovie.shop,https://www.drunkenmovie.shop
# 개발환경: ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_ORIGINS=
