SECRET=

# JWT 설정
# 중요: JWT_ACCESS_SECRET 값은 프론트엔드의 NEXTAUTH_SECRET과 반드시 동일해야 합니다.
# NextAuth가 이 시크릿으로 JWT를 발급하고, 백엔드 JwtStrategy가 동일한 시크릿으로 검증합니다.
# 최소 32자 이상의 무작위 문자열 사용 (예: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRE_TIME=3600s
REFRESH_TOKEN_EXPIRE_TIME=7d
MOVIE_SECRET=

#PRISMA 설정
DATABASE_URL="mysql://root:root@mysql:3306/moviereview"

#MULTER 설정
MULTER_DEST=./uploads

# server port
API_GATEWAY_PORT=3030
AUTH_SERVER_PORT=50051
USER_SERVER_PORT=50052

# CORS 설정
# 허용할 도메인을 콤마로 구분하여 입력 (공백 없이)
# 예) ALLOWED_ORIGINS=https://drunkenmovie.shop,https://www.drunkenmovie.shop
# 개발환경: ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_ORIGINS=
